{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "PromptBridge",
  "version": "0.1.0",
  "identifier": "com.promptbridge.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PromptBridge",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 640,
        "resizable": true,
        "center": true
      },
      {
        "label": "overlay",
        "title": "PromptBridge",
        "width": 820,
        "height": 560,
        "minWidth": 720,
        "minHeight": 500,
        "resizable": true,
        "center": true,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
